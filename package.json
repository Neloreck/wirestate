{
  "name": "wirestate-project",
  "version": "1.0.0-experimental.15",
  "description": "Dependency-injected service state for React and Lit applications",
  "private": true,
  "author": "Syrotenko Igor",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm build:dts && pnpm build:esm && pnpm build:cjs && pnpm build:pkg",
    "build:cjs": "rolldown -c cli/build/rolldown.cjs.config.ts",
    "build:dts": "rolldown -c cli/build/rolldown.dts.config.ts",
    "build:esm": "rolldown -c cli/build/rolldown.esm.config.ts",
    "build:extension": "pnpm --filter wirestate-devtools-extension run build",
    "build:pkg": "tsx cli/deploy/prepare.ts",
    "clean": "rimraf ./target",
    "deploy": "pnpm pre-deploy && tsx cli/deploy/publish.ts",
    "deploy:experimental": "pnpm pre-deploy && tsx cli/deploy/publish.ts --tag experimental",
    "dev:extension": "pnpm --filter wirestate-devtools-extension run dev",
    "format": "prettier --write \"**/*.(js|ts|tsx|md)\" && eslint . --fix",
    "format:check": "prettier --check \"**/*.(js|ts|tsx|md)\"",
    "lint": "eslint .",
    "pre-deploy": "pnpm clean && pnpm lint && pnpm format:check && pnpm typecheck && pnpm test && pnpm build && pnpm test:e2e",
    "purge": "npx rimraf ./node_modules */node_modules */**/node_modules",
    "refresh:browserslist": "pnpm dlx update-browserslist-db@latest && pnpm dedupe browserslist caniuse-lite update-browserslist-db electron-to-chromium node-releases baseline-browser-mapping",
    "test": "jest --config cli/test/jest.config.mjs",
    "test:tc39": "jest --config cli/test/jest.config.mjs --selectProjects tc39",
    "test:coverage": "jest --config cli/test/jest.config.mjs --coverage",
    "test:e2e": "jest --config cli/test/jest.package-consumption.config.mjs --runInBand",
    "test:extension": "jest --config cli/test/jest.extension.config.mjs",
    "typecheck": "tsc --noEmit",
    "typecheck:cli": "tsc -p cli/tsconfig.json --noEmit",
    "typecheck:extension": "pnpm --filter wirestate-devtools-extension run typecheck",
    "docs:api": "typedoc",
    "docs:dev": "vitepress dev docs",
    "docs:build": "pnpm docs:api && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "version:packages": "tsx cli/deploy/bump-version.ts"
  },
  "devDependencies": {
    "@adobe/lit-mobx": "^2.2.2",
    "@babel/core": "^8.0.1",
    "@babel/plugin-proposal-decorators": "^8.0.2",
    "@babel/plugin-transform-class-properties": "^8.0.1",
    "@babel/plugin-transform-class-static-block": "^8.0.1",
    "@babel/plugin-transform-modules-commonjs": "^8.0.1",
    "@babel/plugin-transform-private-methods": "^8.0.1",
    "@babel/plugin-transform-private-property-in-object": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-react": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@eslint/js": "^9.39.4",
    "@lit-labs/preact-signals": "^1.0.3",
    "@lit/context": "^1.1.6",
    "@lit/reactive-element": "^2.1.2",
    "@preact/signals-core": "^1.14.3",
    "@preact/signals-react": "^3.10.2",
    "@swc/core": "^1.15.43",
    "@swc/helpers": "^0.5.23",
    "@swc/jest": "^0.2.39",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/ncp": "^2.0.8",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "babel-jest": "^30.4.1",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jsdoc": "^63.0.7",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lit": "^3.3.3",
    "mobx": "^6.16.1",
    "mobx-react-lite": "^4.1.1",
    "ncp": "^2.0.0",
    "pnpm": "^11.9.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rimraf": "^6.1.3",
    "rolldown": "^1.1.3",
    "rolldown-plugin-dts": "^0.26.0",
    "rollup-plugin-swc3": "^0.12.1",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitepress": "^1.6.4"
  }
}
