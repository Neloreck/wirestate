{
  "name": "wirestate-project",
  "version": "0.7.0-experimental.8",
  "description": "Store management library based on mobx and inversify",
  "private": true,
  "author": "Syrotenko Igor",
  "license": "MIT",
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "build": "pnpm build:dts && pnpm build:esm && pnpm build:cjs && pnpm build:pkg",
    "build:cjs": "rollup -c cli/build/rollup.cjs.config.js --bundleConfigAsCjs",
    "build:dts": "rollup -c cli/build/rollup.dts.config.js --bundleConfigAsCjs",
    "build:esm": "rollup -c cli/build/rollup.esm.config.js --bundleConfigAsCjs",
    "build:pkg": "ts-node cli/deploy/prepare.ts",
    "build:ptb": "rollup -c cli/build/rollup.esm.portable.config.js --bundleConfigAsCjs",
    "build:ptb:debug": "npx cross-env LIB_DEBUG_LOGGING=true rollup -c cli/build/rollup.esm.portable.config.js --bundleConfigAsCjs",
    "clean": "rimraf ./target",
    "deploy": "pnpm pre-deploy && ts-node cli/deploy/publish.ts",
    "deploy:experimental": "pnpm pre-deploy && ts-node cli/deploy/publish.ts --tag experimental",
    "format": "prettier --write \"**/*.(js|ts|tsx|md)\" && eslint . --fix",
    "format:check": "prettier --check \"**/*.(js|ts|tsx|md)\"",
    "lint": "eslint .",
    "pre-deploy": "pnpm clean && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm build:ptb && pnpm test:package-consumption",
    "purge": "npx rimraf ./node_modules */node_modules */**/node_modules",
    "refresh:browserslist": "pnpm dlx update-browserslist-db@latest && pnpm dedupe browserslist caniuse-lite update-browserslist-db electron-to-chromium node-releases baseline-browser-mapping",
    "test": "jest --config cli/test/jest.config.js --detectOpenHandles --maxWorkers=100%",
    "test:package-consumption": "jest --config cli/test/jest.package-consumption.config.js --runInBand",
    "typecheck": "tsc --noEmit",
    "docs:api": "typedoc",
    "docs:dev": "vitepress dev docs",
    "docs:build": "pnpm docs:api && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "version:packages": "ts-node cli/deploy/bump-version.ts"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/node": "^7.29.7",
    "@babel/plugin-proposal-decorators": "^7.29.7",
    "@babel/plugin-transform-class-properties": "^7.29.7",
    "@babel/plugin-transform-modules-commonjs": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@lit-labs/signals": "^0.2.0",
    "@lit/context": "^1.1.6",
    "@lit/reactive-element": "^2.1.2",
    "@preact/signals-react": "^3.10.1",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/ncp": "^2.0.8",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "babel-jest": "^30.4.1",
    "babel-plugin-macros": "^3.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-plugin-transform-typescript-metadata": "^0.4.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jsdoc": "^63.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "inversify": "^8.1.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lit": "^3.3.3",
    "mobx": "^6.15.4",
    "mobx-react-lite": "^4.1.1",
    "ncp": "^2.0.0",
    "pnpm": "^11.1.3",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.4",
    "rollup-plugin-clear": "^2.0.7",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-import-alias": "^1.0.10",
    "rollup-plugin-visualizer": "^6.0.11",
    "signal-polyfill": "^0.2.2",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitepress": "^1.6.4"
  }
}
