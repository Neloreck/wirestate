{
  "name": "wirestate",
  "version": "1.0.0-experimental.15",
  "description": "Compatibility package for Wirestate core, React, MobX, and Signals APIs",
  "sideEffects": false,
  "author": "Syrotenko Igor",
  "homepage": "https://github.com/Neloreck/wirestate#readme",
  "license": "MIT",
  "main": "./cjs/index.js",
  "module": "./esm/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./esm/index.js",
      "require": "./cjs/index.js"
    },
    "./mobx": {
      "types": "./mobx.d.ts",
      "import": "./esm/mobx.js",
      "require": "./cjs/mobx.js"
    },
    "./signals": {
      "types": "./signals.d.ts",
      "import": "./esm/signals.js",
      "require": "./cjs/signals.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Neloreck/wirestate.git"
  },
  "bugs": {
    "url": "https://github.com/Neloreck/wirestate/issues"
  },
  "keywords": [
    "wirestate",
    "state-management",
    "class-based",
    "context",
    "declarative",
    "react",
    "mobx",
    "signals",
    "ioc",
    "di",
    "dependency-injection",
    "state",
    "store",
    "typescript"
  ],
  "dependencies": {
    "@wirestate/core": "1.0.0-experimental.15",
    "@wirestate/react": "1.0.0-experimental.15",
    "@wirestate/mobx": "1.0.0-experimental.15",
    "@wirestate/react-mobx": "1.0.0-experimental.15",
    "@wirestate/signals": "1.0.0-experimental.15",
    "@wirestate/react-signals": "1.0.0-experimental.15"
  },
  "peerDependencies": {
    "@preact/signals-core": ">=1.13.0",
    "@preact/signals-react": ">=3.8.0",
    "mobx": ">=6.0.0",
    "react": ">=16.8.0 <20.0.0"
  },
  "peerDependenciesMeta": {
    "@preact/signals-core": {
      "optional": true
    },
    "@preact/signals-react": {
      "optional": true
    },
    "mobx": {
      "optional": true
    }
  }
}
