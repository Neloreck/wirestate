{
  "name": "wirestate",
  "version": "1.0.0-experimental.4",
  "description": "Compatibility package for Wirestate core, React, MobX, and Signals APIs",
  "sideEffects": false,
  "author": "Syrotenko Igor",
  "homepage": "https://github.com/Neloreck/wirestate#readme",
  "license": "MIT",
  "main": "./cjs/development/index.js",
  "module": "./esm/development/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": {
        "production": "./esm/production/index.js",
        "default": "./esm/development/index.js"
      },
      "require": {
        "production": "./cjs/production/index.js",
        "default": "./cjs/development/index.js"
      }
    },
    "./mobx": {
      "types": "./mobx.d.ts",
      "import": {
        "production": "./esm/production/mobx.js",
        "default": "./esm/development/mobx.js"
      },
      "require": {
        "production": "./cjs/production/mobx.js",
        "default": "./cjs/development/mobx.js"
      }
    },
    "./signals": {
      "types": "./signals.d.ts",
      "import": {
        "production": "./esm/production/signals.js",
        "default": "./esm/development/signals.js"
      },
      "require": {
        "production": "./cjs/production/signals.js",
        "default": "./cjs/development/signals.js"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Neloreck/wirestate.git"
  },
  "bugs": {
    "url": "https://github.com/Neloreck/wirestate/issues"
  },
  "keywords": [
    "wirestate",
    "state-management",
    "class-based",
    "context",
    "declarative",
    "react",
    "mobx",
    "signals",
    "inversify",
    "ioc",
    "di",
    "dependency-injection",
    "state",
    "store",
    "typescript"
  ],
  "dependencies": {
    "@wirestate/core": "1.0.0-experimental.4",
    "@wirestate/react": "1.0.0-experimental.4",
    "@wirestate/mobx": "1.0.0-experimental.4",
    "@wirestate/react-mobx": "1.0.0-experimental.4",
    "@wirestate/react-signals": "1.0.0-experimental.4",
    "inversify": "^8.1.0"
  },
  "peerDependencies": {
    "react": ">=16.8.0 <20.0.0",
    "reflect-metadata": ">=0.2.0",
    "tslib": ">=2.5.0"
  },
  "optionalDependencies": {
    "@preact/signals-react": ">=3.0.0",
    "mobx": ">=6.0.0"
  }
}
