{
  "name": "@wirestate/lit",
  "version": "1.0.0-experimental.7",
  "description": "Lit providers, decorators, and controllers for Wirestate services",
  "sideEffects": false,
  "author": "Syrotenko Igor",
  "homepage": "https://github.com/Neloreck/wirestate#readme",
  "license": "MIT",
  "main": "./cjs/development/index.js",
  "module": "./esm/development/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": {
        "production": "./esm/production/index.js",
        "default": "./esm/development/index.js"
      },
      "require": {
        "production": "./cjs/production/index.js",
        "default": "./cjs/development/index.js"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Neloreck/wirestate.git"
  },
  "bugs": {
    "url": "https://github.com/Neloreck/wirestate/issues"
  },
  "keywords": [
    "class-based",
    "declarative",
    "management",
    "manager",
    "lit",
    "lit-element",
    "web-components",
    "ioc",
    "di",
    "dependency-injection",
    "state",
    "store",
    "typescript"
  ],
  "dependencies": {},
  "peerDependencies": {
    "@wirestate/core": "1.0.0-experimental.7",
    "@lit/reactive-element": ">=2.0.0",
    "@lit/context": ">=1.0.0",
    "tslib": ">=2.5.0"
  }
}
