{
  "name": "@wirestate/core",
  "version": "1.0.0-experimental.11",
  "description": "State management core with built-in dependency injection",
  "sideEffects": [
    "**/metadata-symbol-polyfill.js"
  ],
  "author": "Syrotenko Igor",
  "homepage": "https://github.com/Neloreck/wirestate#readme",
  "license": "MIT",
  "main": "./cjs/index.js",
  "module": "./esm/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./esm/index.js",
      "require": "./cjs/index.js"
    },
    "./devtools": {
      "types": "./devtools.d.ts",
      "import": "./esm/devtools.js",
      "require": "./cjs/devtools.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Neloreck/wirestate.git"
  },
  "bugs": {
    "url": "https://github.com/Neloreck/wirestate/issues"
  },
  "keywords": [
    "wirestate",
    "state-management",
    "class-based",
    "declarative",
    "framework-agnostic",
    "ioc",
    "di",
    "dependency-injection",
    "service-container",
    "event-bus",
    "command-bus",
    "query-bus",
    "scoped-services",
    "state",
    "store",
    "typescript"
  ],
  "dependencies": {
    "@swc/helpers": "^0.5.23"
  }
}
