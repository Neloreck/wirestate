{
  "name": "@wirestate/core",
  "version": "1.0.0-experimental.3",
  "description": "State management core with InversifyJS dependency injection",
  "sideEffects": false,
  "author": "Syrotenko Igor",
  "homepage": "https://github.com/Neloreck/wirestate#readme",
  "license": "MIT",
  "main": "./cjs/development/index.js",
  "module": "./esm/development/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": {
        "production": "./esm/production/index.js",
        "default": "./esm/development/index.js"
      },
      "require": {
        "production": "./cjs/production/index.js",
        "default": "./cjs/development/index.js"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Neloreck/wirestate.git"
  },
  "bugs": {
    "url": "https://github.com/Neloreck/wirestate/issues"
  },
  "keywords": [
    "wirestate",
    "state-management",
    "class-based",
    "declarative",
    "framework-agnostic",
    "inversify",
    "inversifyjs",
    "ioc",
    "di",
    "dependency-injection",
    "service-container",
    "event-bus",
    "command-bus",
    "query-bus",
    "scoped-services",
    "state",
    "store",
    "typescript"
  ],
  "dependencies": {
    "inversify": "^8.1.0"
  },
  "peerDependencies": {
    "reflect-metadata": ">=0.2.0",
    "tslib": ">=2.5.0"
  },
  "optionalDependencies": {}
}
