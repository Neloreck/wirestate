{
  "name": "@wirestate/react-mobx",
  "version": "1.0.0-experimental.9",
  "description": "MobX React reactivity binding (mobx-react-lite) for Wirestate React services",
  "sideEffects": false,
  "author": "Syrotenko Igor",
  "homepage": "https://github.com/Neloreck/wirestate#readme",
  "license": "MIT",
  "main": "./cjs/development/index.js",
  "module": "./esm/development/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": {
        "production": "./esm/production/index.js",
        "default": "./esm/development/index.js"
      },
      "require": {
        "production": "./cjs/production/index.js",
        "default": "./cjs/development/index.js"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Neloreck/wirestate.git"
  },
  "bugs": {
    "url": "https://github.com/Neloreck/wirestate/issues"
  },
  "keywords": [
    "class-based",
    "context",
    "declarative",
    "management",
    "manager",
    "mobx",
    "react",
    "ioc",
    "di",
    "dependency-injection",
    "state",
    "store",
    "typescript"
  ],
  "dependencies": {
    "mobx-react-lite": "^4.0.0"
  },
  "peerDependencies": {
    "mobx": ">=6.0.0",
    "react": ">=16.8.0 <20.0.0"
  },
  "optionalDependencies": {}
}
