{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "types": ["chrome", "node"],
    "paths": {
      "@/*": ["./src/*"],
      // Dev-time shortcut: resolve the public devtools specifier straight to the barrel source so a
      // change to the RC protocol reflects here immediately. Points at the published barrel
      // (devtools.ts) so the extension type-checks against the exact public surface consumers get.
      // Core now uses verbatimModuleSyntax, so pulling its graph into this strict program is clean.
      "@wirestate/core/devtools": ["../../src/wirestate-core/devtools.ts"]
    }
  },
  "include": ["src", "vite.config.ts", "manifest.config.ts"]
}
