{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "types": ["chrome", "node", "jest"],
    "paths": {
      "@/*": ["./src/*"],
      "@wirestate/core/devtools": ["../src/wirestate-core/devtools.ts"],
      "@wirestate/core": ["../src/wirestate-core/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts", "manifest.config.ts"]
}
